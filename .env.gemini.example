# Free Gemini API (gemini-3.1-flash-lite is free-tier: ~1,000 req/day, 15 req/min).
# Get a key (no credit card) at https://aistudio.google.com -> "Get API key".
GEMINI_API_KEY=replace_with_your_gemini_api_key

# Optional safety net: extra keys from other Google accounts for auto-failover
# when a key hits its daily/minute quota. Uncomment and fill as needed.
# GEMINI_API_KEY_2=second_account_key
# GEMINI_API_KEY_3=third_account_key

GEMINI_MODEL=gemini-3.1-flash-lite
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
GEMINI_TIMEOUT_SECONDS=60
